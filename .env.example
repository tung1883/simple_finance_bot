TOKEN=BOT_TOKEN
PROXY_URL=OPEN_AI_PROXY

# Optional — spreadsheet sync (either put google-service-account.json in this folder, or set path below)
# GOOGLE_SERVICE_ACCOUNT_FILE=C:/path/to/service-account.json

# Default: user creates a Sheet, shares SA as Editor, runs /linksheet in Telegram.
# Set true only if the service account has Drive quota (rare for new accounts):
# GOOGLE_SHEETS_AUTO_CREATE=true

# Sharing (optional — SA invites these Gmail addresses; may not work on all user-owned files):
# GOOGLE_SHEETS_SHARE_EMAILS=you@gmail.com
# GOOGLE_SHEETS_SHARE_ROLE=writer
# GOOGLE_SHEETS_PUBLIC_LINK=true
